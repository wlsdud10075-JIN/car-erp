# ════════════════════════════════════════════════════════════════════════
# ⚠️  APP_KEY 변경 절대 금지 — RRN(주민·법인등록번호) 영구 손실 위험
# ════════════════════════════════════════════════════════════════════════
# nice_reg_owner_rrn 컬럼이 APP_KEY로 암호화되어 있어 키가 바뀌면 모든 RRN
# 데이터를 영원히 복호화할 수 없게 됩니다. 자세한 절차: docs/operations/key-rotation.md
# - 새 PC 세팅 시: 다른 PC의 APP_KEY 값을 그대로 복사. `php artisan key:generate` 금지.
# - 운영 배포 시: 최초 1회만 발급. 즉시 안전한 곳(1Password / AWS Secrets Manager 등)에 백업.
# ════════════════════════════════════════════════════════════════════════
APP_NAME=car-erp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ════════════════════════════════════════════════════════════════════════
# 운영 관리자 계정 (ProductionSeeder — `php artisan db:seed` 시 생성)
# ════════════════════════════════════════════════════════════════════════
# 평문 'password' 대신 아래 값으로 관리자 2개를 생성한다. 미설정 시 해당 계정은
# 건너뛰고 경고만 출력(시드 자체는 진행). 설정 후에는 `php artisan config:clear`
# 후 `db:seed` 해야 반영됨(config:cache 환경에서 누락 방지).
#   - ADMIN_* : 시스템관리자(super) — 개발/시스템 관리
#   - BOSS_*  : 최고관리자(admin)  — 고객사 측 최고관리자
ADMIN_NAME=시스템관리자
ADMIN_EMAIL=
ADMIN_PASSWORD=
BOSS_NAME=최고관리자
BOSS_EMAIL=
BOSS_PASSWORD=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=car_erp
DB_USERNAME=root
DB_PASSWORD=

# 큐 11-3: db:backup artisan command이 사용하는 mysqldump 경로 (선택)
# Windows XAMPP는 자동 탐지 (C:\xampp\mysql\bin\mysqldump.exe).
# Linux 운영(AWS)은 보통 PATH에서 mysqldump 발견 → 비워둬도 됨.
MYSQLDUMP_PATH=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# 차량 업로드 서류(말소·수출신고서·B/L) 저장 디스크. 로컬=public / AWS 배포 시 s3 (용량 확보).
VEHICLE_DOCS_DISK=public
# DB 백업 원격 디스크. 설정 시 db:backup 이 mysqldump 결과를 이 디스크에도 업로드(예: s3). 빈 값=로컬만.
DB_BACKUP_DISK=
# mysqldump 실행 경로 (db:backup). Windows 기본 자동 / Linux 보통 /usr/bin/mysqldump.
MYSQLDUMP_PATH=
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# NICE 차량정보 — ssancar-erp /provide/api/nice-lookup/ 미들웨어 경유 (NICE 직접 호출 X)
NICE_PROVIDE_URL=
NICE_PROVIDE_TOKEN=

VITE_APP_NAME="${APP_NAME}"
