# ════════════════════════════════════════════════════════════════════════
# ⚠️  APP_KEY 변경 절대 금지 — RRN(주민·법인등록번호) 영구 손실 위험
# ════════════════════════════════════════════════════════════════════════
# nice_reg_owner_rrn 컬럼이 APP_KEY로 암호화되어 있어 키가 바뀌면 모든 RRN
# 데이터를 영원히 복호화할 수 없게 됩니다. 자세한 절차: docs/operations/key-rotation.md
# - 새 PC 세팅 시: 다른 PC의 APP_KEY 값을 그대로 복사. `php artisan key:generate` 금지.
# - 운영 배포 시: 최초 1회만 발급. 즉시 안전한 곳(1Password / AWS Secrets Manager 등)에 백업.
# ════════════════════════════════════════════════════════════════════════
APP_NAME=car-erp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=car_erp
DB_USERNAME=root
DB_PASSWORD=

# 큐 11-3: db:backup artisan command이 사용하는 mysqldump 경로 (선택)
# Windows XAMPP는 자동 탐지 (C:\xampp\mysql\bin\mysqldump.exe).
# Linux 운영(AWS)은 보통 PATH에서 mysqldump 발견 → 비워둬도 됨.
MYSQLDUMP_PATH=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# NICE 차량정보 — ssancar-erp /provide/api/nice-lookup/ 미들웨어 경유 (NICE 직접 호출 X)
NICE_PROVIDE_URL=
NICE_PROVIDE_TOKEN=

VITE_APP_NAME="${APP_NAME}"
